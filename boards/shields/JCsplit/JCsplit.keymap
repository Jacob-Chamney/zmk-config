/*
 * JCsplit — Clean 42-key Corne keymap
 * Colemak-DH base + QWERTY/WASD GAME layer
 * Home row mods: GACS (GUI/Alt/Ctrl/Shift, pinky→index)
 *
 * Layer-tap thumbs:
 *   L: Esc/MEDIA  Spc/NAV  Tab
 *   R: Ent/SYM    Bsp/NUM  Del/UTIL
 *
 * Special behavior:
 *   Backspace = Backspace
 *   Shift + Backspace = Delete
 *
 * Insert is available on NAV and UTIL.
 *
 * DIAG layer: hold both outer thumbs (MEDIA + UTIL simultaneously).
 * Has bootloader/reset on each half, plus BT_CLR / BT_CLR_ALL.
 *
 * Important:
 *   Keep your OS keyboard layout set to QWERTY.
 *   The keyboard firmware handles Colemak-DH.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE  0
#define NAV   1
#define UTIL  2
#define MEDIA 3
#define NUM   4
#define SYM   5
#define GAME  6
#define DIAG  7

/* Key-position groups for HRM hold-trigger */
#define KEYS_L 0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29
#define KEYS_R 6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35
#define THUMBS 36 37 38 39 40 41

/ {
    behaviors {
        /*
         * Home row mod, left hand.
         * Colemak-DH home row:
         *   A R S T
         *
         * Mods:
         *   A = GUI
         *   R = Alt
         *   S = Ctrl
         *   T = Shift
         */
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "balanced";
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;
            bindings = <&kp>, <&kp>;
        };

        /*
         * Home row mod, right hand.
         * Colemak-DH home row:
         *   N E I O
         *
         * Mods:
         *   N = Shift
         *   E = Ctrl
         *   I = Alt
         *   O = GUI
         */
        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "balanced";
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;
            bindings = <&kp>, <&kp>;
        };

        /*
         * Backspace/Delete mod-morph:
         *   Backspace = Backspace
         *   Shift + Backspace = Delete
         */
        bspc_del: backspace_delete {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
            bindings = <&kp BSPC>, <&kp DEL>;
        };

        /*
         * Custom NUM layer-tap using the Backspace/Delete mod-morph.
         *
         * Usage:
         *   &lt_num_bspc NUM 0
         *
         * Result:
         *   Tap = Backspace
         *   Shift + Tap = Delete
         *   Hold = NUM
         *
         * The second parameter is a dummy value because ZMK hold-tap
         * behaviors require exactly two binding cells.
         */
        lt_num_bspc: layer_tap_num_backspace {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <125>;
            flavor = "balanced";
            bindings = <&mo>, <&bspc_del>;
        };
    };

    combos {
        compatible = "zmk,combos";

        /*
         * Both inner thumbs together = toggle GAME on/off.
         * Limited to BASE so it does not accidentally trigger from other layers.
         */
        combo_game_toggle {
            timeout-ms = <50>;
            key-positions = <38 39>;
            bindings = <&tog GAME>;
            layers = <BASE>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        /*
         * Holding both outer thumbs:
         *   Left outer = MEDIA
         *   Right outer = UTIL
         * activates DIAG.
         */
        tri_diag {
            if-layers = <MEDIA UTIL>;
            then-layer = <DIAG>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /*
         * BASE — Colemak-DH.
         *
         * Layout:
         *   Q W F P B   J L U Y ;
         *   A R S T G   M N E I O
         *   Z X C D V   K H , . /
         */
        base_layer {
            display-name = "BASE";
            bindings = <
&kp TAB    &kp Q        &kp W        &kp F         &kp P         &kp B         &kp J    &kp L         &kp U         &kp Y         &kp SEMI        &bspc_del
&kp ESC    &hml LGUI A  &hml LALT R  &hml LCTRL S  &hml LSHFT T  &kp G         &kp M    &hmr RSHFT N  &hmr RCTRL E  &hmr LALT I   &hmr RGUI O     &kp SQT
&kp LSHFT  &kp Z        &kp X        &kp C         &kp D         &kp V         &kp K    &kp H         &kp COMMA     &kp DOT       &kp FSLH        &kp RET
                                     &lt MEDIA ESC &lt NAV SPACE &kp TAB      &lt SYM RET &lt_num_bspc NUM 0 &lt UTIL DEL
            >;
        };

        /*
         * NAV — daily navigation + editing.
         *
         * Right hand:
         *   Arrows, Insert, Home, End, PgUp, PgDn, Delete.
         *
         * Left hand:
         *   Undo/Cut/Copy/Paste/Redo and word movement/deletion.
         */
        nav_layer {
            display-name = "NAV";
            bindings = <
&trans  &kp K_UNDO    &kp K_CUT     &kp K_COPY    &kp K_PASTE  &kp K_REDO   &kp K_REDO  &kp K_PASTE  &kp K_COPY  &kp K_CUT   &kp K_UNDO  &trans
&trans  &kp LC(LEFT)  &kp LC(RIGHT) &kp LC(BSPC)  &kp LC(DEL)  &kp CAPS     &kp LEFT    &kp DOWN     &kp UP      &kp RIGHT   &kp INS     &trans
&trans  &trans        &trans        &trans        &trans       &trans       &kp HOME    &kp PG_DN    &kp PG_UP   &kp END     &kp DEL     &trans
                                &trans        &trans        &trans       &kp RET     &bspc_del   &kp DEL
            >;
        };

        /*
         * UTIL — utility, F-keys, system keys, and game-support keys.
         */
        util_layer {
            display-name = "UTIL";
            bindings = <
&trans  &kp F1       &kp F2       &kp F3       &kp F4       &kp F5          &kp F6        &kp F7        &kp F8        &kp F9      &kp F10       &trans
&trans  &kp CAPS     &kp INS      &kp HOME     &kp PG_UP    &kp DEL         &kp LEFT      &kp DOWN      &kp UP        &kp RIGHT   &kp F11       &trans
&trans  &kp PSCRN    &kp SLCK     &kp END      &kp PG_DN    &kp PAUSE_BREAK &kp LC(LEFT)  &kp LC(RIGHT) &kp LC(BSPC)  &kp LC(DEL) &kp F12       &trans
                                &trans        &trans        &trans         &kp K_APP     &trans       &trans
            >;
        };

        /*
         * MEDIA — Bluetooth, output, and media controls only.
         */
        media_layer {
            display-name = "MEDIA";
            bindings = <
&trans  &trans      &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3   &trans       &trans         &trans       &trans         &trans       &trans
&trans  &none       &none        &none        &none        &out OUT_TOG   &kp C_PREV   &kp C_VOL_DN   &kp C_VOL_UP &kp C_NEXT     &trans       &trans
&trans  &trans      &trans       &trans       &trans       &trans         &trans       &trans         &kp C_MUTE   &kp C_PP       &kp C_STOP   &trans
                                 &trans       &trans       &trans         &kp C_STOP   &kp C_PP       &kp C_MUTE
            >;
        };

        /*
         * NUM — numbers, brackets, and common numeric operators.
         */
        num_layer {
            display-name = "NUM";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans     &kp LBKT      &kp N7    &kp N8    &kp N9    &kp RBKT      &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans     &kp SEMI      &kp N4    &kp N5    &kp N6    &kp EQUAL     &trans
&trans  &trans     &trans     &kp BSLH   &kp GRAVE  &trans     &kp N0        &kp N1    &kp N2    &kp N3    &kp MINUS     &trans
                              &trans     &trans     &trans     &kp DOT       &trans    &kp COMMA
            >;
        };

        /*
         * SYM — programming symbols.
         */
        sym_layer {
            display-name = "SYM";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans     &kp LBRC      &kp AMPS  &kp ASTRK &kp LPAR  &kp RBRC      &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans     &kp COLON     &kp DLLR  &kp PRCNT &kp CARET &kp PLUS      &trans
&trans  &trans     &trans     &trans     &trans     &trans     &kp TILDE     &kp EXCL  &kp AT    &kp HASH  &kp PIPE      &trans
                              &trans     &trans     &kp UNDER  &trans        &kp LBRC  &kp RBRC
            >;
        };

        /*
         * GAME — QWERTY/WASD-friendly gaming layer.
         *
         * This intentionally stays QWERTY even though BASE is Colemak-DH.
         * Most games expect QWERTY physical positions.
         *
         * Hold right Enter thumb for UTIL access:
         *   F-keys, Insert/Delete, Home/End, PgUp/PgDn, etc.
         */
        game_layer {
            display-name = "GAME";
            bindings = <
&kp ESC    &kp T      &kp Q      &kp W      &kp E      &kp R         &kp Y     &kp U       &kp I       &kp O       &kp P         &bspc_del
&kp TAB    &kp LSHFT  &kp A      &kp S      &kp D      &kp F         &kp H     &kp J       &kp K       &kp L       &kp SEMI      &kp SQT
&kp LCTRL  &kp Z      &kp X      &kp C      &kp V      &kp B         &kp N     &kp M       &kp COMMA   &kp DOT     &kp FSLH      &kp RET
                                 &kp LCTRL  &kp SPACE  &kp LALT      &lt UTIL RET &bspc_del &tog GAME
            >;
        };

        /*
         * DIAG — firmware/system recovery layer.
         * No ZMK Studio unlock.
         */
        diag_layer {
            display-name = "DIAG";
            bindings = <
&bootloader  &none      &none      &none      &none      &none         &none           &none         &none         &none         &none           &bootloader
&sys_reset   &none      &none      &none      &none      &none         &none           &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3    &sys_reset
&none        &none      &none      &none      &none      &none         &none           &out OUT_USB  &out OUT_BLE  &bt BT_CLR    &bt BT_CLR_ALL  &none
                                   &none      &none      &none         &none           &none         &none
            >;
        };
    };
};

/*
 * Tune the default &lt layer-tap behavior used on the thumbs.
 */
&lt {
    quick-tap-ms = <200>;
    require-prior-idle-ms = <125>;
};
