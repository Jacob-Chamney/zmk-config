/*
 * JCsplit — Optimized 42-key Corne keymap
 * Miryoku-inspired QWERTY + GAME layer
 * Home row mods: GACS (GUI/Alt/Ctrl/Shift, pinky→index)
 *
 * Layer-tap thumbs:
 *   L: Esc/MEDIA  Spc/NAV  Tab/MOUSE
 *   R: Ent/SYM    Bsp/NUM  Del/FUN
 *
 * DIAG layer: hold both outer thumbs (MEDIA + FUN simultaneously).
 * Has bootloader/reset on each half, plus BT_CLR / BT_CLR_ALL / studio_unlock.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

#define BASE  0
#define NAV   1
#define MOUSE 2
#define MEDIA 3
#define NUM   4
#define SYM   5
#define FUN   6
#define GAME  7
#define DIAG  8

/* Key-position groups for HRM hold-trigger */
#define KEYS_L 0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29
#define KEYS_R 6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35
#define THUMBS 36 37 38 39 40 41

/ {
    behaviors {
        /* Home row mod, left hand — only triggers hold when paired with right/thumb keys */
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "balanced";
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;
            bindings = <&kp>, <&kp>;
        };
        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "balanced";
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;
            bindings = <&kp>, <&kp>;
        };
    };

    combos {
        compatible = "zmk,combos";
        /* Both inner thumbs together = toggle GAME on/off */
        combo_game_toggle {
            timeout-ms = <50>;
            key-positions = <38 39>;
            bindings = <&tog GAME>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";
        /* Holding both outer thumbs (MEDIA + FUN) brings up DIAG */
        tri_diag {
            if-layers = <MEDIA FUN>;
            then-layer = <DIAG>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            display-name = "BASE";
            bindings = <
&kp TAB    &kp Q        &kp W        &kp E         &kp R         &kp T         &kp Y    &kp U         &kp I         &kp O         &kp P           &kp BSPC
&kp ESC    &hml LGUI A  &hml LALT S  &hml LCTRL D  &hml LSHFT F  &kp G         &kp H    &hmr RSHFT J  &hmr RCTRL K  &hmr LALT L   &hmr RGUI SEMI  &kp SQT
&kp LSHFT  &kp Z        &kp X        &kp C         &kp V         &kp B         &kp N    &kp M         &kp COMMA     &kp DOT       &kp FSLH        &kp RET
                                     &lt MEDIA ESC &lt NAV SPACE &lt MOUSE TAB &lt SYM RET &lt NUM BSPC &lt FUN DEL
            >;
        };

        nav_layer {
            display-name = "NAV";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans      &kp K_REDO   &kp K_PASTE  &kp K_COPY  &kp K_CUT   &kp K_UNDO  &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &kp CAPS    &kp LEFT     &kp DOWN     &kp UP      &kp RIGHT   &kp INS     &trans
&trans  &trans     &trans     &trans     &trans     &trans      &kp HOME     &kp PG_DN    &kp PG_UP   &kp END     &kp DEL     &trans
                              &trans     &trans     &trans      &kp RET      &kp BSPC     &kp DEL
            >;
        };

        mouse_layer {
            display-name = "MOUSE";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans      &msc SCRL_UP &mkp MB4    &mkp MCLK    &mkp MB5    &msc SCRL_DOWN &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans      &mmv MOVE_LEFT &mmv MOVE_DOWN &mmv MOVE_UP &mmv MOVE_RIGHT &trans &trans
&trans  &trans     &trans     &trans     &trans     &trans      &trans       &mkp LCLK   &mkp RCLK    &trans      &trans         &trans
                              &trans     &trans     &trans      &mkp LCLK    &mkp RCLK   &mkp MCLK
            >;
        };

        media_layer {
            display-name = "MEDIA";
            bindings = <
&trans  &bt BT_CLR  &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3   &trans       &trans         &trans       &trans         &trans       &trans
&trans  &kp LGUI    &kp LALT     &kp LCTRL    &kp LSHFT    &out OUT_TOG   &kp C_PREV   &kp C_VOL_DN   &kp C_VOL_UP &kp C_NEXT     &trans       &trans
&trans  &trans      &trans       &trans       &trans       &trans         &trans       &trans         &kp C_MUTE   &kp C_PP       &kp C_STOP   &trans
                                 &trans       &trans       &trans         &kp C_STOP   &kp C_PP       &kp C_MUTE
            >;
        };

        num_layer {
            display-name = "NUM";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans     &kp LBKT      &kp N7    &kp N8    &kp N9    &kp RBKT      &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans     &kp SEMI      &kp N4    &kp N5    &kp N6    &kp EQUAL     &trans
&trans  &trans     &trans     &kp BSLH   &kp GRAVE  &trans     &kp N0        &kp N1    &kp N2    &kp N3    &kp MINUS     &trans
                              &trans     &trans     &trans     &kp DOT       &trans    &kp COMMA
            >;
        };

        sym_layer {
            display-name = "SYM";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans     &kp LBRC      &kp AMPS  &kp ASTRK &kp LPAR  &kp RBRC      &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans     &kp COLON     &kp DLLR  &kp PRCNT &kp CARET &kp PLUS      &trans
&trans  &trans     &trans     &trans     &trans     &trans     &kp TILDE     &kp EXCL  &kp AT    &kp HASH  &kp PIPE      &trans
                              &trans     &trans     &kp UNDER  &trans        &kp LPAR  &kp RPAR
            >;
        };

        fun_layer {
            display-name = "FUN";
            bindings = <
&trans  &trans     &trans     &trans     &trans     &trans     &kp PSCRN     &kp F7    &kp F8    &kp F9    &kp F12       &trans
&trans  &kp LGUI   &kp LALT   &kp LCTRL  &kp LSHFT  &trans     &kp SLCK      &kp F4    &kp F5    &kp F6    &kp F11       &trans
&trans  &trans     &trans     &trans     &trans     &trans     &kp PAUSE_BREAK &kp F1  &kp F2    &kp F3    &kp F10       &tog GAME
                              &trans     &trans     &trans     &kp K_APP     &kp SPACE &trans
            >;
        };

        game_layer {
            display-name = "GAME";
            bindings = <
&kp ESC    &kp T      &kp Q      &kp W      &kp E      &kp R         &kp Y    &kp U      &kp I      &kp O      &kp P         &kp BSPC
&kp TAB    &kp LSHFT  &kp A      &kp S      &kp D      &kp F         &kp H    &kp J      &kp K      &kp L      &kp SEMI      &kp SQT
&kp LCTRL  &kp Z      &kp X      &kp C      &kp V      &kp B         &kp N    &kp M      &kp COMMA  &kp DOT    &kp FSLH      &kp RET
                                 &kp LCTRL  &kp SPACE  &kp LALT      &kp RET  &kp BSPC   &tog GAME
            >;
        };

        /*
         * DIAG layer — held when both outer thumbs are pressed (MEDIA + FUN).
         * Bootloader/sys_reset only act on the half they're pressed from, so each
         * side has its own pair. Most keys are &none to avoid stray output during
         * the awkward two-thumb hold.
         */
        diag_layer {
            display-name = "DIAG";
            bindings = <
&bootloader  &none      &none      &none           &none      &none         &none           &none         &none         &none         &none           &bootloader
&sys_reset   &none      &none      &studio_unlock  &none      &none         &none           &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3    &sys_reset
&none        &none      &none      &none           &none      &none         &none           &out OUT_USB  &out OUT_BLE  &bt BT_CLR    &bt BT_CLR_ALL  &none
                                   &none           &none      &none         &none           &none         &none
            >;
        };
    };
};

/*
 * Tune the default &lt (layer-tap) used on the thumbs.
 *   quick-tap-ms:           tap-then-hold within this window repeats the tap
 *                           instead of activating the layer (this is what
 *                           makes hold-to-repeat-Backspace work)
 *   require-prior-idle-ms:  if a non-layer-tap key was pressed within this
 *                           window, the next layer-tap press resolves to its
 *                           tap action — kills accidental layers during rolls
 */
&lt {
    quick-tap-ms = <200>;
    require-prior-idle-ms = <125>;
};


